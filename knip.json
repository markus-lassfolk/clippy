{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/**/*.test.ts"],
  "project": ["src/**/*.ts"],
  "ignoreDependencies": ["@sentry/core"],
  "ignoreUnresolved": ["bun-types"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreIssues": {
    "src/test/mocks/**": ["exports"],
    "src/lib/ews-client.ts": ["exports"],
    "src/lib/graph-client.ts": ["exports"],
    "src/lib/calendar-range.ts": ["exports"],
    "src/lib/markdown.ts": ["exports"],
    "src/lib/glitchtip-eligibility.ts": ["exports"],
    "src/lib/copilot-graph-client.ts": ["exports"],
    "src/lib/graph-microsoft-search.ts": ["exports"],
    "src/lib/graph-teams-client.ts": ["exports"],
    "src/lib/places-client.ts": ["exports"]
  }
}
